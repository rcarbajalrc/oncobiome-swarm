# OncoBiome Swarm — .env.example
# Copia este archivo como .env y rellena tus claves reales.
# NUNCA subas el archivo .env a GitHub.

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # Obtén la tuya en console.anthropic.com
MEM0_API_KEY=                                    # Opcional — deja vacío para memoria in-memory

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic       # anthropic | ollama | rule_engine
LLM_CONCURRENCY=6            # Llamadas paralelas simultáneas (recomendado: 4-8)
LOG_DECISIONS=true           # Guarda decisiones en logs/decisions.csv

# ── Ollama (solo si LLM_PROVIDER=ollama) ─────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_AGENT_MODEL=llama3.1:8b

# ── Parámetros opcionales (sobreescriben settings.py) ────────────────────────
# Descomenta para sobreescribir el experimento activo.
# Recomendado: usa --experiment en CLI en lugar de estas variables.
# MAX_AGENTS=150
# TOTAL_CYCLES=77
# N_TUMOR_CELLS=12
# N_IMMUNE_CELLS=5
# N_MACROPHAGES=3
# N_PHYTOCHEMICALS=2
# N_NK_CELLS=0
# N_DENDRITIC_CELLS=0
# OPUS_ANALYSIS_INTERVAL=25
